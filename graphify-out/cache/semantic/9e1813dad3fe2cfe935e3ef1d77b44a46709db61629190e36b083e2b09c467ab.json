{"nodes": [{"id": "adr_0001_supabase_self_hosted_su_vps_con_salvataggi_a_checkpoint_decision", "label": "ADR 0001 - Supabase self-hosted su VPS con salvataggi a checkpoint", "file_type": "document", "source_file": "docs/adr/0001-supabase-self-hosted-su-vps-con-salvataggi-a-checkpoint.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "adr_0001_supabase_self_hosted_su_vps_con_salvataggi_a_checkpoint_checkpoint_persistence", "label": "Persistenza a Checkpoint (stato in memoria, scritture atomiche)", "file_type": "rationale", "source_file": "docs/adr/0001-supabase-self-hosted-su-vps-con-salvataggi-a-checkpoint.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Il gioco non interroga il DB durante la simulazione: carica lo stato in memoria a inizio sessione e scrive in transazioni atomiche solo ai Checkpoint. Cosi' la latenza di rete verso la VPS e' irrilevante per design. Accesso psycopg diretto, non PostgREST: i salvataggi sono multi-tabella e servono transazioni vere."}, {"id": "adr_0001_supabase_self_hosted_su_vps_con_salvataggi_a_checkpoint_supabase_on_matilde", "label": "Supabase self-hosted su matilde via Tailscale", "file_type": "rationale", "source_file": "docs/adr/0001-supabase-self-hosted-su-vps-con-salvataggi-a-checkpoint.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Scartati stack locale (stato legato a una macchina; l'utente vuole il DB sul proprio server) e Supabase cloud (free tier in pausa, chiavi su rete pubblica). Limite accettato: senza Tailscale il gioco non parte. Nota di attuazione 2026-06-12: lo stack 'gia' attivo' in realta' non esisteva ed e' stato installato in /opt/formulamanager-supabase (Postgres 17, porte solo su IP Tailscale, Kong HTTPS su 8444)."}], "edges": [{"source": "adr_0001_supabase_self_hosted_su_vps_con_salvataggi_a_checkpoint_decision", "target": "supabase_readme_db_procedures", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr/0001-supabase-self-hosted-su-vps-con-salvataggi-a-checkpoint.md", "source_location": "Nota di attuazione", "weight": 1.0}, {"source": "adr_0001_supabase_self_hosted_su_vps_con_salvataggi_a_checkpoint_checkpoint_persistence", "target": "context_checkpoint", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr/0001-supabase-self-hosted-su-vps-con-salvataggi-a-checkpoint.md", "source_location": null, "weight": 1.0}, {"source": "adr_0001_supabase_self_hosted_su_vps_con_salvataggi_a_checkpoint_checkpoint_persistence", "target": "context_career", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr/0001-supabase-self-hosted-su-vps-con-salvataggi-a-checkpoint.md", "source_location": null, "weight": 1.0}, {"source": "adr_0001_supabase_self_hosted_su_vps_con_salvataggi_a_checkpoint_supabase_on_matilde", "target": "supabase_readme_db_procedures", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr/0001-supabase-self-hosted-su-vps-con-salvataggi-a-checkpoint.md", "source_location": "Nota di attuazione", "weight": 1.0}, {"source": "adr_0001_supabase_self_hosted_su_vps_con_salvataggi_a_checkpoint_supabase_on_matilde", "target": "supabase_readme_fm_database_url", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "docs/adr/0001-supabase-self-hosted-su-vps-con-salvataggi-a-checkpoint.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "checkpoint_persistence_flow", "label": "Flusso di persistenza a Checkpoint della Carriera", "nodes": ["context_checkpoint", "adr_0001_supabase_self_hosted_su_vps_con_salvataggi_a_checkpoint_checkpoint_persistence", "readme_fm_persistence", "supabase_readme_fm_database_ur